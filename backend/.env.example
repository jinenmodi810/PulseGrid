# =============================================================================
# Copy to ".env" and fill in (see backend/README.md)
#   cp .env.example .env
#
# For coordinator / admin inspection: copy ADMIN_* lines too — without
# ADMIN_EMAIL and ADMIN_PASSWORD the API returns "not configured".
# =============================================================================

# Paste your Aura "Connection URI" here (neo4j+s://....databases.neo4j.io)
NEO4J_URI=neo4j+s://1404817b.databases.neo4j.io
NEO4J_USERNAME=1404817b
NEO4J_PASSWORD=KN-cBrs4Jt9g-dM0H-Wy1V_cE6QiWoAQfPqBcyWHURg
# IMPORTANT (Aura): use the database name from the Aura console — almost always `neo4j`.
# Do NOT set this to the instance id (the hex in the URI); wrong DB = empty data or long hangs.
# Classic Aura default graph: neo4j. If you see "database neo4j does not exist", use AUTO (or leave empty)
# so the driver uses the server home database, or set the exact name from the Aura console.
NEO4J_DATABASE=neo4j
# Optional — tighten Bolt / transaction waits if /admin/* or /health/neo4j feels hung.
# NEO4J_CONNECTION_TIMEOUT=15
# NEO4J_CONNECTION_ACQUISITION_TIMEOUT=25
# NEO4J_TRANSACTION_TIMEOUT=25
# Optional — Gemini for /ai/guidance/* (server-side only; never expose key to Flutter)

GEMINI_API_KEY=AIzaSyCm_YghDygAAWlKet7d-ZU8UlLQuwkcKSc

# e.g. gemini-2.0-flash, gemini-1.5-flash

GEMINI_MODEL=gemini-2.0-flash

# Hackathon coordinator gate (plain text). Set both or POST /auth/admin-login returns ok:false.
ADMIN_EMAIL=coordinator@pulsegrid.local
ADMIN_PASSWORD=admin123

# Returned to the app on successful admin login; send the same value in header X-Admin-Session for /admin/*.
ADMIN_SESSION_MARKER=admin-hackathon

# Required for victim/volunteer/org email login (HS256). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret-for-demo-only
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ElevenLabs — server-side only for POST /voice-sos/transcribe (never put in Flutter).
# ELEVENLABS_STT_MODE=cloud | off   (off → transcribe returns 503; use /voice-sos/preview with typed text)
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL_ID=scribe_v2
ELEVENLABS_STT_MODE=cloud
# ELEVENLABS_AGENT_ID=   # reserved for future conversational agent flows

# Optional — Aura instance labels (for your notes; app ignores unless you wire them)

# AURA_INSTANCEID=
# AURA_INSTANCENAME=

# --- PostgreSQL (system of record) + Alembic ---
# Example (adjust user/host/port/db): postgresql+psycopg2://jinenmodi@localhost:5432/pulsegrid_db
# DATABASE_URL=
# When true, enables POST /data/users for local/integration testing (keep false in production).
# PG_WRITE_ROUTES_ENABLED=false

# --- Domain event outbox → Kafka/Redpanda (optional) ---
# Leave unset: outbox rows stay pending; API still works. Use docker compose Redpanda at repo root.
# KAFKA_BOOTSTRAP_SERVERS=localhost:19092
# KAFKA_OUTBOX_TOPIC=pulsegrid.domain.events
# KAFKA_TOPIC_ROUTING_ENABLED=true
# KAFKA_TOPIC_INCIDENT_EVENTS=pulsegrid.incident.events
# KAFKA_TOPIC_ORGANIZATION_EVENTS=pulsegrid.organization.events
# KAFKA_TOPIC_VOLUNTEER_EVENTS=pulsegrid.volunteer.events
# KAFKA_TOPIC_AUDIT_EVENTS=pulsegrid.audit.events
# OUTBOX_MAX_PUBLISH_ATTEMPTS=10
# OUTBOX_PUBLISHER_BATCH_SIZE=50
# OUTBOX_PUBLISHER_POLL_SECONDS=2.0

# --- Bronze lake ingestion (MinIO / S3-compatible local store) ---
# BRONZE_KAFKA_CONSUMER_GROUP=pulsegrid-bronze-consumer
# BRONZE_KAFKA_TOPICS=pulsegrid.incident.events,pulsegrid.organization.events,pulsegrid.volunteer.events
# BRONZE_BUCKET=pulsegrid-bronze
# BRONZE_PREFIX=events
# BRONZE_S3_ENDPOINT_URL=http://localhost:9000
# BRONZE_S3_ACCESS_KEY=minioadmin
# BRONZE_S3_SECRET_KEY=minioadmin
# BRONZE_S3_REGION=us-east-1
# BRONZE_S3_USE_SSL=false
# BRONZE_POLL_TIMEOUT_MS=1000
# BRONZE_GZIP_ENABLED=false

# --- Silver ETL (Bronze -> Silver Parquet) ---
# SILVER_BUCKET=pulsegrid-bronze
# SILVER_BRONZE_PREFIX=events
# SILVER_PREFIX=silver
# SILVER_REJECTED_PREFIX=silver/_rejected
# SILVER_CHECKPOINT_KEY=silver/_checkpoints/bronze_to_silver_checkpoint.json
# SILVER_FULL_REFRESH=false

# --- Gold marts ---
# GOLD_BUCKET=pulsegrid-bronze
# GOLD_PREFIX=gold
# GOLD_REJECTED_PREFIX=gold/_rejected
# ANALYTICS_LOCAL_GOLD_ROOT=backend/data/gold_cache
# ANALYTICS_AUTO_SYNC=true
